# ════════════════════════════════════════════════
# BEO — Environment Configuration
# Copy to .env and fill in all values before first run
# .env is gitignored — never commit with real values
# ════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=          # your personal chat ID — get from @userinfobot

# ── LiteLLM ──────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_DATABASE_URL=sqlite:///./litellm.db

# ── Google AI Studio — promo key pool ────────────
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=

# ── Primary non-promo key ─────────────────────────
OPENROUTER_API_KEY=

# ── Internal paths (defaults match Docker mounts) ─
LITELLM_CONFIG_PATH=/app/litellm_config.yaml
TLD_CACHE_PATH=/root/.openclaw/tlds.txt

# ── Operational thresholds ────────────────────────
TLD_REFRESH_DAYS=30              # how often to refresh IANA TLD list
PAGER_ALERT_DAYS=10              # alert if TLD cache stale beyond this
