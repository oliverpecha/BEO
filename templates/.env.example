# ==============================================================================
# BEO EXTENSION SNIPPET
# ==============================================================================
# BEO is designed to run alongside OpenClaw. Do not use this as a standalone 
# .env file. Instead, append these variables to your existing OpenClaw .env file 
# located at ~/openclaw/.env
# ==============================================================================

# LiteLLM Gatekeeper configuration
LITELLM_MASTER_KEY=sk-your-secure-master-key-here

# (Optional) Add any specific API keys for The Minions or The Oracle here if 
# they differ from the primary keys already defined in OpenClaw.
# GEMINI_KEY_1=...
