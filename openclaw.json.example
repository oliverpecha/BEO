{
  "_comment": "BEO reference config — copy relevant blocks into ~/.openclaw/openclaw.json",

  "agents": {
    "defaults": {
      "maxConcurrent": 10,
      "sandbox": { "mode": "off" },
      "model": {
        "primary": "litellm/tier-1-brain",
        "fallbacks": ["litellm/tier-2-desk"]
      }
    },
    "list": [
      { "id": "tier-1-brain",      "params": { "maxTokens": 8192 } },
      { "id": "tier-2-desk",       "params": { "maxTokens": 8192 } },
      { "id": "tier-3-field",      "params": { "maxTokens": 8192 } },
      { "id": "tier-4-extraction", "params": { "maxTokens": 8192 } },
      { "id": "tier-nano-router",  "params": { "maxTokens": 2048 } }
    ]
  },

  "gateway": {
    "nodes": {
      "denyCommands": [
        "camera.snap", "camera.clip", "screen.record",
        "contacts.add", "calendar.add", "reminders.add", "sms.send"
      ]
    }
  }
}
